{
  "expo": {
    "name": "tobafarm-mobile",
    "slug": "tobafarm-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/tobafarm-logo.png",
    "scheme": "tobafarmmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/tobafarm-logo.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.anonymous.tobafarmmobile"
    },
    "web": {
      "favicon": "./assets/images/tobafarm-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ]
    ]
  }
}